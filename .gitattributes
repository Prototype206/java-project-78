# Auto detect text files and perform LF normalization
* text=auto

# Java files should use LF
*.java text eol=lf

# Gradle files should use LF
*.gradle text eol=lf
*.gradle.kts text eol=lf
gradlew text eol=lf

# Windows script files should use CRLF
*.bat text eol=crlf

# Binary files
*.jar binary
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary

# Force LF for shell scripts
*.sh text eol=lf
